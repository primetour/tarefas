// ============================================================
// PRIMETOUR — Regras completas do Firestore
// Cole este conteúdo em:
// Firebase Console > Firestore Database > Regras
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Master: isMaster:true OU role == 'master'
    function isMaster() {
      return isAuth() && (
        userDoc().isMaster == true ||
        userDoc().role     == 'master' ||
        userDoc().roleId   == 'master'
      );
    }

    // Admin: master OU role admin
    function isAdmin() {
      return isMaster() || (isAuth() && (
        userDoc().role   == 'admin' ||
        userDoc().roleId == 'admin'
      ));
    }

    // Manager: admin OU role manager/coordinator
    function isManager() {
      return isAdmin() || (isAuth() && (
        userDoc().role   == 'manager'     ||
        userDoc().roleId == 'manager'     ||
        userDoc().role   == 'coordinator' ||
        userDoc().roleId == 'coordinator'
      ));
    }

    // Portal manager: admin OU tem permissão portal_manage no role
    function isPortalManager() {
      return isAdmin() || isManager();
    }

    // v4.49.50+ Helper genérico de permission granular (espelha store.can()):
    // master → sempre true; override per-user (userDoc.permissionOverrides[perm])
    // tem prioridade; senão lê role base (roles/{roleId}.permissions[perm]).
    //
    // v4.49.58+ FIX: usa .get(key, default) em vez de [key] direto. Acesso
    // direto em map ausente lançava runtime error em rules, derrubando
    // toda a expressão (rule retornava false mesmo quando role tinha perm).
    // Esse era o bug do analista que "não conseguia criar plataforma/tipo
    // /categoria" mesmo com a permission ligada no role — sem o
    // permissionOverrides setado, o branch de role base nunca executava.
    function hasPermission(perm) {
      return isMaster() || (isAuth() && (
        // Override per-user. .get aceita map ausente → retorna 'undef'.
        // Só `== true` se tiver explicit true; undef ou false → cai no role.
        userDoc().get('permissionOverrides', {}).get(perm, false) == true ||
        // Role base. exists() defende contra roleId inválido.
        (exists(/databases/$(database)/documents/roles/$(userDoc().roleId)) &&
         get(/databases/$(database)/documents/roles/$(userDoc().roleId)).data
           .get('permissions', {}).get(perm, false) == true)
      ));
    }

    // ── Usuários ──────────────────────────────────────────────
    // SECURITY NOTE (audit 2026-05-15): read aberto pra auth users por
    // necessidade operacional — UI exibe nome+avatar+role+sector em centenas
    // de pontos (atribuição de tarefas, comentários, dashboards, etc.).
    // Restringir read quebraria a app inteira.
    // MITIGAÇÃO: campos sensíveis (senha hash, MFA secrets, tokens) NUNCA
    // são gravados aqui — Firebase Auth gerencia separadamente.
    // FUTURO: subcollection `users/{uid}/private/{doc}` pra dados confidenciais
    // (permissions overrides, audit metadata) com rule isAdmin() OR self.
    match /users/{userId} {
      allow read:   if isAuth();
      // Admin pode criar qualquer usuário; SSO auto-provisioning: próprio UID
      allow create: if isAdmin() || (isAuth() && request.auth.uid == userId);
      // CRITICAL FIX (pentest 2026-05-03): self-update NAO pode tocar
      // campos sensiveis (role/isMaster/roleId/visibleSectors/permissions/active).
      // Antes: rule permitia member auto-escalar pra master.
      // Agora: admin pode tudo; user pode atualizar proprio profile MENOS
      // os campos sensiveis listados.
      allow update: if isAdmin() || (
        request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role','isMaster','roleId','visibleSectors','permissions','active','sector','nucleos','nucleo'])
      );
      // 4.48.4+ Self-cleanup de doc pending_* via email match.
      //
      // Por que: quando admin pré-cadastra um SSO user, cria-se um doc
      // 'users/pending_<email_slug>' (placeholder). No 1º login do user,
      // o auto-provision em auth.js cria 'users/{uid}' e tenta deletar
      // o pending. Como o user é 'member' (ainda não admin), a rule
      // antiga `allow delete: if isAdmin()` bloqueava → pending ficava
      // preso pra sempre, gerando duplicidade no listing de Users.
      //
      // Esta carve-out permite QUE o próprio dono (verificado pelo email
      // do auth token) limpe seu pending. Seguro: só o legitimo holder
      // do email consegue passar, ninguém pode deletar pending alheio.
      allow delete: if isAdmin() || (
        userId.matches('^pending_.*') &&
        isAuth() &&
        resource.data.email == request.auth.token.email
      );
    }

    // ── Projetos ──────────────────────────────────────────────
    // 4.40.21+ (security audit) — update/delete agora exigem ownership ou role.
    // Antes: qualquer auth user alterava/deletava projeto alheio.
    match /projects/{projectId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        isManager()
        || resource.data.createdBy == request.auth.uid
        || (resource.data.members != null && request.auth.uid in resource.data.members)
      );
      allow delete: if isManager() || (isAuth() && resource.data.createdBy == request.auth.uid);
    }

    // ── Tarefas ───────────────────────────────────────────────
    // 4.40.21+ (security audit) — read SEMPRE exige auth (era aberta pra status
    // done/in_progress como legacy do portal calendar; vetor de info-leak).
    // Update/delete exigem ownership: creator, assignee, ou manager+.
    match /tasks/{taskId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        isManager()
        || resource.data.createdBy == request.auth.uid
        || (resource.data.assignees != null && request.auth.uid in resource.data.assignees)
        || (resource.data.observers != null && request.auth.uid in resource.data.observers)
      );
      allow delete: if isAuth() && (
        isManager()
        || resource.data.createdBy == request.auth.uid
      );
    }

    // ── Templates de tarefas recorrentes ──────────────────────
    match /recurring_task_templates/{tplId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (isManager() || resource.data.createdBy == request.auth.uid);
    }

    // ── Logs de auditoria ─────────────────────────────────────
    // CRITICAL FIX (pentest 2026-05-03): client NAO pode injetar audit logs.
    // Antes: allow create: if isAuth() — qualquer auth user injetava logs falsos
    // pra esconder rastro ou bloatar coleção.
    // Agora: client CRIA logs apenas com action whitelisted (eventos do client
    // que nao tem origem server, ex: 'page.viewed') E os campos obrigatorios.
    // Logs de seguranca (auth.login, security.*, lgpd.*, system.*) sao gerados
    // server-side via Cloud Functions (Admin SDK bypassa rules).
    // ── Presence (online users em tempo real) ────────────────
    // Cada user só escreve seu próprio doc (presence/{uid}). Todos lêem.
    // Rate-limit natural: heartbeat a cada 30s já é suficiente pra evitar abuse.
    match /presence/{userId} {
      allow read:   if isAuth();
      allow write:  if isAuth() && request.auth.uid == userId;
      allow delete: if isAuth() && request.auth.uid == userId;
    }

    // ── Presence daily — acumulador de tempo de uso por usuário/dia ──
    // Doc ID: '{uid}_{YYYY-MM-DD}'. User só escreve nos próprios docs.
    // Leitura aberta (autenticado) pra dashboards de produtividade agregarem.
    match /presence_daily/{docId} {
      allow read:   if isAuth();
      // Só permite write se uid no payload bate com auth uid
      // (validacao via request.resource.data.uid; docId começa com uid)
      allow write:  if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read:   if isAdmin();
      // Client pode criar log de qualquer ação de domínio (tasks, projects,
      // goals, csat, feedbacks, content_calendar, page, client, user, etc),
      // EXCETO ações server-only (auth/security/lgpd/system) — essas só
      // entram via Cloud Function com Admin SDK.
      // Validações:
      //   - userId precisa ser o próprio uid (não pode forjar logs de outros)
      //   - action precisa ser string no formato `<dominio>.<acao>` ou
      //     `<dominio>.<sub>.<acao>` (lowercase + underscore)
      //   - prefixos auth/security/lgpd/system bloqueados
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.action is string &&
        request.resource.data.action.matches('^[a-z_]+[.][a-z_]+([.][a-z_]+)?$') &&
        !request.resource.data.action.matches('^(auth|security|lgpd|system)[.].*$');
      allow update, delete: if false;
    }

    // ── CSAT ──────────────────────────────────────────────────
    match /csat_surveys/{surveyId} {
      // Leitura: autenticados + público (cliente externo carrega via token)
      allow read:           if true;
      // Criação: apenas usuários autenticados
      allow create:         if isAuth();
      // Update: autenticado OU respondente externo (valida que não muda campos críticos)
      allow update:         if isAuth()
                            || (
                              // Respondente externo — só pode preencher resposta, não alterar taskId/token
                              request.resource.data.taskId == resource.data.taskId
                              && request.resource.data.token == resource.data.token
                              && request.resource.data.createdBy == resource.data.createdBy
                            );
      allow delete:         if isAdmin();
    }

    // ── CSAT periodic run locks ─────────────────────────────────
    // 4.34.12+ Doc por (typeId, winId) representa disparo do bolsão.
    // Lock atômico (primeiro a criar = wins) garante idempotência.
    match /csat_periodic_runs/{runId} {
      allow read:    if isAuth();
      allow create:  if isAuth();
      allow update:  if isAuth();
      allow delete:  if isAdmin();
    }

    // ── Content meta (4.35.13+) ─────────────────────────────────
    // Plataformas (Instagram, Newsletter, ...) e tipos de conteúdo
    // (Post, Reel, ...). Substituem PLATFORM_OPTIONS/CONTENT_TYPE_OPTIONS
    // hardcoded — agora editáveis via /content-config.
    // Leitura aberta (dropdowns precisam carregar mesmo pra users sem
    // permissão de admin); escrita: admin OU permission granular
    // content_calendar_meta_manage (v4.49.50+ liberou pra analista/coord
    // quando admin marcar a perm no role ou override); delete só master.
    match /content_platforms/{id} {
      allow read:   if isAuth();
      allow create: if isAdmin() || hasPermission('content_calendar_meta_manage');
      allow update: if isAdmin() || hasPermission('content_calendar_meta_manage');
      allow delete: if isMaster();
    }
    match /content_contents/{id} {
      allow read:   if isAuth();
      allow create: if isAdmin() || hasPermission('content_calendar_meta_manage');
      allow update: if isAdmin() || hasPermission('content_calendar_meta_manage');
      allow delete: if isMaster();
    }
    match /content_categories/{id} {
      allow read:   if isAuth();
      allow create: if isAdmin() || hasPermission('content_calendar_meta_manage');
      allow update: if isAdmin() || hasPermission('content_calendar_meta_manage');
      allow delete: if isMaster();
    }

    // ── System Feedback (4.35.3+) ───────────────────────────────
    // Bugs/sugestões/dúvidas/elogios sobre o sistema. Não confundir
    // com /feedbacks (gestão de pessoas, manager → subordinado).
    // Qualquer auth user CRIA seu próprio feedback (authorUid bate);
    // só admin LÊ/EDITA; só master DELETA.
    match /system_feedback/{fbId} {
      allow read:   if isAuth() && (isAdmin() || resource.data.authorUid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuth() && isAdmin();
      allow delete: if isAuth() && isMaster();
    }

    // ── Integrações ───────────────────────────────────────────
    match /integrations/{intId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Workspaces ────────────────────────────────────────────
    match /workspaces/{wsId} {
      // Leitura: qualquer autenticado (a sidebar lista squads para navegação;
      // a UI filtra exibição por membership, mas a leitura é aberta).
      allow read: if isAuth();
      allow create: if isManager();
      // Update: somente admin do sistema ou admin do workspace.
      // Self-join foi removido — squads são atribuídos pelo gestor.
      allow update: if isAdmin()
                    || (isAuth() && request.auth.uid in resource.data.adminIds);
      allow delete: if isAdmin();
    }

    match /workspace_invites/{inviteId} {
      allow read: if isAdmin()
                  || (isAuth() && resource.data.createdBy == request.auth.uid)
                  || (isAuth() && resource.data.email == request.auth.token.email);
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Metas v2 ──────────────────────────────────────────────
    match /goals/{goalId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin()
                    || (isAuth() && resource.data.gestorId      == request.auth.uid)
                    || (isAuth() && resource.data.responsavelId == request.auth.uid)
                    || (isAuth() && resource.data.createdBy     == request.auth.uid);
      allow delete: if isAdmin()
                    || (isAuth() && resource.data.createdBy == request.auth.uid);
    }

    // ── Avaliações de metas ───────────────────────────────────
    match /goal_evaluations/{evalId} {
      allow read:   if isAuth();
      allow create: if isAuth() && (isAdmin() || request.resource.data.gestorId == request.auth.uid);
      allow update: if isAuth() && (isAdmin() || resource.data.gestorId == request.auth.uid);
      allow delete: if isAuth() && (isAdmin() || resource.data.gestorId == request.auth.uid);
    }

    // ── Solicitações do portal ────────────────────────────────
    match /requests/{reqId} {
      // Criação pública (portal) com validação: deve ter campos obrigatórios
      allow create:         if true
                            && request.resource.data.keys().hasAll(['requesterName', 'typeName', 'requestingArea'])
                            && request.resource.data.requesterName is string
                            && request.resource.data.requesterName.size() > 0
                            && request.resource.data.requesterName.size() < 200;
      allow read, update:   if isAuth();
      allow delete:         if isAdmin();
    }

    // ── Ausências / Capacidade ────────────────────────────────
    // 4.40.21+ (security audit) — create exige que userId seja self ou criador
    // tenha permissão de gerenciar ausências de outros.
    match /absences/{absenceId} {
      allow read:   if isAuth();
      allow create: if isAuth() && (
        isManager() || request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if isAdmin()
                            || (isAuth() && resource.data.createdBy == request.auth.uid)
                            || (isAuth() && resource.data.userId    == request.auth.uid);
    }

    // ── Núcleos (estrutura organizacional) ────────────────────
    match /nucleos/{nucleoId} {
      allow read:           if true;  // public — needed for portal de solicitações
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }

    // ── Setores (4.23+ — antes era hardcoded; agora collection editável) ──
    // Mesma política dos núcleos: leitura pública (portal de solicitações
    // mostra dropdown de setores sem login), escrita só admin/master.
    match /sectors/{sectorId} {
      allow read:           if true;
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }

    // ── User notes & reminders (4.24+ — Meu Painel) ─────────
    // Pessoais. Cada doc tem userId; user só vê/edita os próprios.
    match /user_notes/{noteId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete:
                    if isAuth() && resource.data.userId == request.auth.uid;
    }
    match /user_reminders/{remId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete:
                    if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Categorias de tipos de tarefa ─────────────────────────
    match /task_categories/{catId} {
      allow read:           if isAuth();
      allow create, update: if isManager();
      allow delete:         if isAdmin();
    }

    // ── Tipos de tarefa ───────────────────────────────────────
    match /task_types/{typeId} {
      allow read:           if true;  // public — needed for portal de solicitações
      allow create, update: if isManager();
      allow delete:         if isManager();
    }

    // ── Roles (RBAC) ──────────────────────────────────────────
    match /roles/{roleId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Configurações ─────────────────────────────────────────
    match /settings/{settingId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Branding global (logos do app) ────────────────────────
    // Leitura PÚBLICA — necessária pro splash/login mostrarem o
    // logo antes do auth completar. Só URLs (sem dados sensíveis).
    match /app_branding/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Check-in: Reservas de estação ─────────────────────────
    // Qualquer usuário autenticado pode ler (visualizar mapa).
    // Cria a própria reserva (createdBy = auth.uid). Atualizar/excluir:
    // dono da reserva ou admin (gestores podem corrigir/cancelar).
    match /desk_reservations/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && (
                        resource.data.createdBy == request.auth.uid
                        || isAdmin()
                        || isManager()
                      );
      allow delete: if isAuth() && (
                        resource.data.createdBy == request.auth.uid
                        || isAdmin()
                      );
    }

    // ── Check-in: Config (áreas + regras de setor) ────────────
    // Leitura pra todos autenticados (precisa carregar mapa/dropdowns);
    // escrita só admin (config global do escritório).
    match /desk_config/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Ponto eletrônico (jornada) ────────────────────────────
    // Doc por usuário+data. Cada user só vê e edita o próprio.
    // Admin/gestor pode ler tudo (relatório) e corrigir registros.
    match /time_clock/{docId} {
      allow read:   if isAuth() && (
                        resource.data.userId == request.auth.uid
                        || isAdmin()
                        || isManager()
                      );
      // Admin pode lançar ponto de qualquer um (manual entry); user só o próprio
      allow create: if isAuth() && (
                        request.resource.data.userId == request.auth.uid
                        || isAdmin()
                        || isManager()
                      );
      allow update: if isAuth() && (
                        resource.data.userId == request.auth.uid
                        || isAdmin()
                        || isManager()
                      );
      allow delete: if isAdmin();
    }

    // ── Auditoria de ponto (cada edição/exclusão gera entry) ──
    // Append-only: ninguém edita/exclui logs. Admin/gestor lê tudo;
    // colaborador lê os próprios pra ver histórico de correções.
    match /time_clock_audit/{logId} {
      allow read:   if isAuth() && (
                        resource.data.userId == request.auth.uid
                        || isAdmin()
                        || isManager()
                      );
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── Solicitações de correção de ponto ────────────────────
    // Colaborador cria pra própria data; gestor aprova/rejeita.
    match /time_clock_requests/{reqId} {
      allow read:   if isAuth() && (
                        resource.data.userId == request.auth.uid
                        || isAdmin()
                        || isManager()
                      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';
      // Update: gestor (decidir) ou dono (cancelar enquanto pendente)
      allow update: if isAuth() && (
                        isAdmin()
                        || isManager()
                        || (resource.data.userId == request.auth.uid
                            && resource.data.status == 'pending')
                      );
      allow delete: if isAdmin();
    }

    // ── Férias (período aquisitivo + solicitações) ───────────
    // Período aquisitivo é gerado automaticamente / lido por colaborador.
    // Solicitações: colaborador cria; gestor aprova; admin gerencia.
    match /vacation_periods/{periodId} {
      allow read:   if isAuth() && (
                        resource.data.userId == request.auth.uid
                        || isAdmin()
                        || isManager()
                      );
      allow create: if isAuth() && (
                        request.resource.data.userId == request.auth.uid
                        || isAdmin()
                        || isManager()
                      );
      allow update: if isAdmin() || isManager();
      allow delete: if isAdmin();
    }

    match /vacation_requests/{reqId} {
      allow read:   if isAuth() && (
                        resource.data.userId == request.auth.uid
                        || isAdmin()
                        || isManager()
                      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
                        isAdmin()
                        || isManager()
                        || (resource.data.userId == request.auth.uid
                            && resource.data.status == 'pending')
                      );
      allow delete: if isAdmin();
    }

    // ── Performance de Newsletters (Marketing Cloud) ──────────
    // Read: qualquer usuário autenticado (analytics interno)
    // Write: GitHub Actions (Admin SDK bypassa) E master (analise manual / re-extracao /
    //        veredito humano em divergências shadow mode)
    match /mc_performance/{docId} {
      allow read:  if isAuth();
      allow write: if isMaster();
    }

    // ── NL Classifier — Shadow Mode (v4.49.41+) ───────────────
    // Audit collections do agente nl-content-classifier. Gravadas
    // EXCLUSIVAMENTE via Admin SDK (scripts/classify-content-ai.js,
    // promote-ai-to-prod.js, rollback-ai-classification.js).
    // Cliente: read-only pra renderizar sparkline e auditoria.
    // Defesa contra adulteração: write false (Admin SDK bypassa).
    match /nl_ai_classifier_runs/{docId} {
      allow read:               if isAuth();
      allow create, update, delete: if false; // append-only via Admin SDK
    }
    match /nl_classifier_promotions/{docId} {
      allow read:               if isAuth() && isAdmin();
      allow create, update, delete: if false; // append-only via Admin SDK
    }
    match /nl_classifier_rollbacks/{docId} {
      allow read:               if isAuth() && isAdmin();
      allow create, update, delete: if false; // append-only via Admin SDK
    }

    // ── Cache de extração de imagens (Vision API) ─────────────
    // Populated by mc-sync. Master pode ler/escrever pra debug e re-extração.
    match /mc_image_extractions/{docId} {
      allow read:  if isAuth();
      allow write: if isMaster();
    }

    // ── Performance Redes Sociais (Meta Instagram) ────────────
    match /meta_performance/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    match /meta_accounts/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    // ── Performance Google Analytics (GA4) ────────────────────
    match /ga_daily/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    match /ga_pages/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    match /ga_sources/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    match /ga_devices/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    match /ga_countries/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    match /ga_properties/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    match /ga_totals/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    match /ga_meta/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    // ── Portal de Dicas ───────────────────────────────────────
    match /portal_areas/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    match /portal_destinations/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    match /portal_tips/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    match /portal_images/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    match /portal_generations/{docId} {
      allow read:  if isAuth();
      allow create: if isAuth();
      allow update: if false;
    }

    match /portal_tips_stats/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    match /portal_downloads/{docId} {
      allow read:  if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuth() && request.auth.uid == docId.split('_')[0];
    }

    match /portal_terms/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    match /portal_terms_acceptance/{docId} {
      allow read:  if isAuth();
      allow create: if isAuth();
      allow update: if false;
    }

    match /portal_web_links/{docId} {
      allow read:   if true;  // public — link holder can read
      allow create: if isAuth();
      // Update público: só permite incrementar viewCount, sem alterar token/content
      allow update: if isAuth()
                    || (request.resource.data.token == resource.data.token
                        && request.resource.data.content == resource.data.content);
      allow delete: if isAuth() && isAdmin();
    }

    match /ai_settings/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    // ── Hub de Marketing ──────────────────────────────────────
    match /landing_pages/{docId} {
      // Público só lê páginas publicadas; autenticados lêem todas
      allow read:   if isAuth()
                    || resource.data.status == 'published';
      allow create: if isAuth() && isPortalManager();
      allow update: if isAuth() && isPortalManager();
      allow delete: if isAuth() && isPortalManager();
    }

    match /news_monitor/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    match /news_clipping/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    // ── Marcas trackadas (Share of Voice) ─────────────────────
    // Auto-seed: qualquer auth user pode criar/ler (precisa pra primeira abertura).
    // Delete restrito a admin pra evitar perda acidental.
    match /tracked_brands/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && isAdmin();
    }

    // ── Photo cache (Unsplash/Wikipedia) — server-only ────────
    // Cache de fotos por query hash. Escrita via Cloud Function (Admin SDK).
    // Leitura proibida do client — evita disclosure dos atributos cache+rate-limit state.
    match /photo_cache/{docId} {
      allow read, write: if false;
    }
    match /system_state/{docId} {
      allow read, write: if false;
    }

    // ── Dashboard Insights ───────────────────────────────────
    // Observações estruturadas em qualquer dashboard analítico.
    // Qualquer auth user pode criar/ler. Editar/remover só autor ou admin.
    // Campos adicionais permitidos (sem validação de schema estrito):
    //   - indexKey:   chave do widget ancorado (null = insight geral do dash)
    //   - source:     manual | ai-generated | ai-edited
    //   - aiOriginal: payload original da IA (audit trail quando humano edita)
    match /dashboard_insights/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth()
        && request.resource.data.createdBy.uid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.dashboard is string;
      allow update: if isAuth()
        && (resource.data.createdBy.uid == request.auth.uid || isAdmin())
        && request.resource.data.dashboard == resource.data.dashboard
        && request.resource.data.createdBy.uid == resource.data.createdBy.uid;
      allow delete: if isAuth()
        && (resource.data.createdBy.uid == request.auth.uid || isAdmin());
    }

    // ── Revista Luxury Travel (CMS) ───────────────────────────
    // Edições: leitura pública (auth), escrita admin OU permission luxury_travel_manage.
    function canManageLuxuryTravel() {
      return isAdmin() || (isAuth() && (
        userDoc().permissions != null &&
        userDoc().permissions.luxury_travel_manage == true
      ));
    }
    match /luxury_travel_editions/{docId} {
      allow read:   if isAuth();
      allow create: if canManageLuxuryTravel();
      allow update: if canManageLuxuryTravel();
      allow delete: if canManageLuxuryTravel();
    }
    match /luxury_travel_fonts/{docId} {
      allow read:   if isAuth();
      allow create: if canManageLuxuryTravel();
      allow update: if canManageLuxuryTravel();
      allow delete: if canManageLuxuryTravel();
    }
    match /luxury_travel_settings/{docId} {
      allow read:   if isAuth();
      allow create: if canManageLuxuryTravel();
      allow update: if canManageLuxuryTravel();
      allow delete: if canManageLuxuryTravel();
    }

    // ── Feedbacks ──────────────────────────────────────────────
    // 4.40.21+ (security audit) — read/update agora exigem ownership ou role.
    // Antes: qualquer auth user lia feedbacks confidenciais alheios.
    match /feedbacks/{docId} {
      allow read:   if isAuth() && (
        isManager()
        || resource.data.collaboratorId == request.auth.uid
        || resource.data.managerId == request.auth.uid
        || resource.data.createdBy == request.auth.uid
      );
      allow create: if isAuth() && (
        isManager() || request.resource.data.collaboratorId == request.auth.uid
      );
      allow update: if isAuth() && (
        isAdmin()
        || resource.data.managerId == request.auth.uid
        || resource.data.createdBy == request.auth.uid
      );
      allow delete: if isAuth() && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    match /feedback_schedules/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    match /arts_templates/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    match /arts_categories/{catId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    match /arts_generations/{docId} {
      allow read:   if isAuth() && isPortalManager();
      allow create: if isAuth();
    }

    match /ai_generations/{docId} {
      allow read:   if isAuth() && isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    match /portal_categories/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    // 4.40.18+ Custom segments (segmentos extras além dos 11 builtin).
    // Leitura PÚBLICA pra portal-view.html renderizar web links sem auth.
    // Escrita só admin (mesmo padrão de portal_categories).
    match /portal_segments/{segKey} {
      allow read:  if true;
      allow write: if isAuth() && isAdmin();
    }

    // ── Roteiros de Viagem ──────────────────────────────────
    // 4.40.31+ (Sprint 1 hardening) — update agora exige ownership ou
    // collaborator ou manager. Antes: qualquer auth user editava roteiro
    // alheio (vetor de tampering identificado em audit bancária).
    //
    // Modelo:
    //   - consultantId    → dono primário (criador)
    //   - collaboratorIds → array de UIDs com permissão de edição
    //   - isManager       → roteiros_manage role bypass
    //
    // Read continua aberto pra auth (UI lista todos respeita hierarquia em código).
    match /roteiros/{roteiroId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.consultantId == request.auth.uid;
      allow update: if isAuth() && (
        isManager()
        || resource.data.consultantId == request.auth.uid
        || (resource.data.collaboratorIds != null
            && request.auth.uid in resource.data.collaboratorIds)
      );
      allow delete: if isAuth() && (isAdmin() || resource.data.consultantId == request.auth.uid);
    }

    match /roteiro_generations/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // v4.49.109+ Fila de geração de roteiros via IA — Cloud Function
    // `processRoteiroQueue` (Admin SDK) processa em background, max 5
    // paralelos globais. Client cria + lê próprios docs; updates só via
    // Cloud Function (bypassa rules).
    match /roteiro_generations_queue/{queueId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'queued';
      allow update: if false;   // Cloud Function bypassa via Admin SDK
      allow delete: if isAuth()
                    && resource.data.userId == request.auth.uid
                    && resource.data.status == 'queued';
    }

    // v4.50.0+ Banco de Roteiros — curadoria da empresa
    // Read: qualquer usuário autenticado (consultores leem)
    // Write: quem pode gerenciar destinos (princípio: curadoria é curadoria)
    match /roteiros_bank/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth() && (
                      isAdmin()
                      || hasPermission('portal_destinations_manage')
                      || hasPermission('portal_manage')
                    );
      allow update: if isAuth() && (
                      isAdmin()
                      || hasPermission('portal_destinations_manage')
                      || hasPermission('portal_manage')
                    );
      allow delete: if isAuth() && isAdmin();   // apenas master deleta hard
    }

    // v4.50.0+ Categorias de hospedagem do Banco — defaults + custom CRUD
    match /roteiro_bank_categories/{key} {
      allow read:   if isAuth();
      allow create, update, delete: if isAuth() && (
                      isAdmin()
                      || hasPermission('portal_destinations_manage')
                      || hasPermission('portal_manage')
                    );
    }

    // v4.50.1+ Coleções (Classic/Exclusive/Corporate) — mesma regra
    match /roteiro_bank_collections/{key} {
      allow read:   if isAuth();
      allow create, update, delete: if isAuth() && (
                      isAdmin()
                      || hasPermission('portal_destinations_manage')
                      || hasPermission('portal_manage')
                    );
    }

    match /roteiro_web_links/{token} {
      allow read:   if true;   // public — link holder can read
      allow create: if isAuth();
      // Update público: só permite incrementar viewCount + atualizar lastViewedAt.
      // Antes a regra checava apenas que roteiroId/createdBy não mudaram,
      // mas isso permitia injetar/alterar QUALQUER outro campo. Agora forçamos
      // que apenas viewCount e lastViewedAt podem ser modificados.
      allow update: if isAuth()
                    || (
                      request.resource.data.roteiroId == resource.data.roteiroId
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['viewCount', 'lastViewedAt'])
                    );
      allow delete: if isAuth() && isAdmin();
    }

    // ── Auditoria de Sites (Core Web Vitals + SEO) ───────────
    match /audit_sites/{siteId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (isAdmin() || resource.data.createdBy == request.auth.uid);

      // Histórico de runs (sub-collection)
      match /runs/{runId} {
        allow read:   if isAuth();
        allow create: if isAuth();
        allow update: if isAuth();
        allow delete: if isAuth() && isAdmin();
      }
    }

    // ── Notificações ─────────────────────────────────────────
    // SECURITY FIX (pentest 2026-05-03): notif spam — qualquer auth user
    // criava notifs pra qualquer recipientId. Atacante podia floodar inbox.
    //
    // Agora: client só cria notifs onde:
    //   1. actorId == request.auth.uid (impede impersonation)
    //   2. type whitelist: prefixos client.*, mention.* permitidos
    //   3. Notifs sistemicas (security.*, lgpd.*, system.*, secrets.*)
    //      apenas via Cloud Functions (Admin SDK bypassa rules)
    //
    // Self-notification permitida (recipientId == uid) pra UX local.
    match /notifications/{notifId} {
      allow create: if isAuth()
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.type is string
        && request.resource.data.type.matches('^(client|mention|task|project|squad|csat|request|goal|portal|feedback|subtask|roteiro)[.][a-z_]+$')
        && !request.resource.data.type.matches('^(security|lgpd|system|auth|secrets)[.].*$');
      // Ler, atualizar e deletar apenas as próprias notificações
      allow read, update, delete: if isAuth()
        && resource.data.recipientId == request.auth.uid;
    }

    // ── Configuração do Sistema (AI config — keys LLM) ─────────
    // SECURITY (Sprint 1 done): Cloud Functions deployed (callLLM, etc.)
    // mantêm keys em Secret Manager. Client NÃO precisa mais ler keys.
    // Apenas admin lê configs gerais (preferences) — keys vão direto pra
    // Functions via env via defineSecret.
    match /system_config/{docId} {
      allow read:  if isAuth() && isAdmin();
      allow write: if isAuth() && isAdmin();
    }

    // ── Segredos do sistema (SEM acesso client-side, só Admin SDK) ──
    // ZERO trust: nenhum cliente lê/escreve. Cloud Functions com
    // service account acessam via Admin SDK.
    // Aqui ficam: SharePoint clientSecret, GitHub PAT, tokens MS app-only,
    // qualquer credencial sensível.
    match /system_secrets/{docId} {
      allow read, write: if false;
    }

    // ── Rate limit counters (per-IP, per-user) — server-only ───
    // Coleção atualizada APENAS por Cloud Functions via Admin SDK.
    // Client nunca lê/escreve (atacante poderia limpar contador).
    match /rate_limits/{docId} {
      allow read, write: if false;
    }
    match /rate_limits_ip/{docId} {
      allow read, write: if false;
    }

    // ── AI Skills ────────────────────────────────────────────
    match /ai_skills/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    // ── AI API Keys (multi-escopo: global, user, nucleo, area) ──
    // SECURITY (Sprint 1 done): callLLM Cloud Function lê via Admin SDK.
    // Client SDK não precisa mais. Keys em Secret Manager (zero exposure).
    match /ai_api_keys/{docId} {
      allow read:  if isAuth() && isAdmin();
      allow write: if isAuth() && isAdmin();
    }

    // ── AI Knowledge Base ────────────────────────────────────
    // SECURITY: documentos corporativos. Por padrão público a auth users,
    // mas se doc tiver `visibility: 'restricted'` exige role match.
    // Classificação obrigatória futura: Public/Internal/Confidential/Restricted
    match /ai_knowledge/{docId} {
      allow read:  if isAuth() && (
                      !('visibility' in resource.data)
                      || resource.data.visibility == 'public'
                      || resource.data.visibility == 'internal'
                      || isAdmin()
                      || (resource.data.visibility == 'sector'
                          && resource.data.sector in (userDoc().visibleSectors || []))
                    );
      allow write: if isAuth() && isAdmin();
    }

    // ── AI Module Hints (prompts customizados por módulo) ───
    match /ai_module_hints/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    // ── AI Usage Logs ────────────────────────────────────────
    match /ai_usage_logs/{docId} {
      allow read:   if isAuth() && isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── AI Agents (IA Hub - novo modelo unificado) ──────────
    // Leitura: todos autenticados (botões na página dependem)
    // Escrita: admin/master only
    match /ai_agents/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    // Backups imutáveis da migração legado → agents
    // Append-only via service; admin pode ler pra restaurar
    match /ai_skills_archive/{docId} {
      allow read:   if isAuth() && isAdmin();
      allow create: if isAuth() && isAdmin();
      allow update, delete: if false;
    }
    match /ai_automations_archive/{docId} {
      allow read:   if isAuth() && isAdmin();
      allow create: if isAuth() && isAdmin();
      allow update, delete: if false;
    }

    // ── AI Action Logs (ações executadas pelo assistente) ────
    match /ai_action_logs/{docId} {
      allow read:   if isAuth() && isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── Calendário de Conteúdo ─────────────────────────────────
    match /content_calendar/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    // ── Meta Posts (Instagram posts importados) ─────────────────
    match /meta_posts/{docId} {
      allow read:  if isAuth();
      allow write: if false; // escrita apenas via GitHub Actions
    }

    // ── AI Automations (tarefas agendadas de IA) ─────────────
    match /ai_automations/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    // ── Reset de senha ────────────────────────────────────────
    match /password_reset_requests/{uid} {
      allow read, write: if isAdmin();
    }

    match /password_reset_results/{uid} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── Dev Hours (sistema de horas de desenvolvimento) ──────
    // Leitura PÚBLICA (sem auth) — habilita o link compartilhável da 4.2.0.
    // Escrita: master-only (gestão privada do dev).
    // Página #dev-hours é acessada APENAS via URL direta (não está no sidebar).
    match /dev_hours/{docId} {
      allow read:  if true;
      allow write: if isMaster();
    }

    // ── BTG Ofertas (DEV/STAGING) ────────────────────────────
    // Migração do projeto BTG Pactual pro Gestor — Fase 1+.
    // Coleção alvo: gestor-btg-lp-builder-staging > btg_ofertas_dev.
    // No projeto de produção (gestor-de-tarefas-primetour) essa coleção
    // não existe — regras ficam inertes lá. Antes do cutover pra prod,
    // criar bloco equivalente pra `btg_ofertas` exigindo SSO Microsoft
    // + permissão `btg_offer_manage`.
    //
    // Postura STAGING: read+write liberados. Justificativa:
    //   - ambiente isolado (projeto Firebase dedicado)
    //   - sem auth setup ainda (POC roda sem login)
    //   - dados de teste, sem PII real
    //   - URL `*.web.app` não divulgada externamente
    match /btg_ofertas_dev/{docId} {
      allow read, write: if true;
    }

    // ── BTG Portal Images (DEV/STAGING) ──────────────────────
    // Banco de imagens de teste pra o picker do BTG (Fase 2.1).
    // Reusa o schema da coleção real `portal_images` (Portal de
    // Dicas) — assim quando migrar pra produção, é só apontar
    // pra `portal_images` em vez de `portal_images_dev`.
    // Sample populado via btg/_internal/seed-portal-images-dev.html
    // com 12 imagens curadas de hoteis premium.
    // Mesma postura permissiva do btg_ofertas_dev (justificativas
    // identicas — staging isolado, sem PII).
    match /portal_images_dev/{docId} {
      allow read, write: if true;
    }

    // ── BTG Solicitações de conteúdo (DEV/STAGING) ───────────
    // Solicitações "Conteúdo e newsletter" geradas pela lista de
    // ofertas BTG (btg/dashboard/ofertas). Mesmo shape da coleção
    // `requests` real do Gestor — no cutover pra prod, o service
    // aponta pra `requests` e a solicitação cai no módulo de
    // Tarefas & Solicitações (setor Marketing).
    // Mesma postura permissiva/justificativa do btg_ofertas_dev.
    match /btg_requests_dev/{docId} {
      allow read, write: if true;
    }
  }
}
